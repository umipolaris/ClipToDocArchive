# Example: infra/env/.env.common
# - 최초 실행 시 doctor/quickstart가 이 파일을 복사해 infra/env/.env.common을 생성합니다.
# - 운영(prod)에서는 반드시 비밀키/비밀번호/도메인 값을 교체하세요.

APP_PROFILE=dev

POSTGRES_DB=archive
POSTGRES_USER=archive
POSTGRES_PASSWORD=archive_pw

DATABASE_URL=postgresql+psycopg://archive:archive_pw@postgres:5432/archive
REDIS_URL=redis://redis:6379/0
INGEST_RETRY_BASE_SECONDS=30
INGEST_RETRY_MAX_SECONDS=1800

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_secret
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio_secret
MINIO_SECURE=false
STORAGE_BUCKET=archive
STORAGE_BACKEND=minio
SESSION_SECRET=change-me-session-secret-for-prod
SESSION_COOKIE_NAME=archive_session
SESSION_MAX_AGE_SECONDS=28800
SESSION_HTTPS_ONLY=false
SESSION_SAME_SITE=lax
READ_ONLY_MODE=false
API_BASE_URL=http://localhost:8000/api

PASSWORD_MIN_LENGTH=10
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=900

OPENCLAW_CALLBACK_URL=http://openclaw:8080/callback/ingest
OPENCLAW_NOTIFY_ENABLED=false
OPENCLAW_ACTION_SECRET=change-me-openclaw-action-secret
OPENCLAW_ACTION_TTL_SECONDS=86400
FRONTEND_BASE_URL=http://localhost:3000
INTERNAL_API_BASE=http://api:8000/api
NEXT_PUBLIC_API_BASE=/api

SEARCH_BACKEND=postgres
SEARCH_AUTO_SYNC=true
MEILI_URL=http://meilisearch:7700
MEILI_API_KEY=
MEILI_INDEX_DOCUMENTS=documents
MEILI_TIMEOUT_SECONDS=3.0
MEILI_ENV=development

BACKUP_ROOT=/backup
BACKUP_CONFIG_ROOT=/config
BACKUP_RETENTION_DAYS=30
